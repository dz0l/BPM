<ui:FluentWindow x:Class="PrintMaestro.Views.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="{DynamicResource History.Title}"
        Width="960"
        Height="520"
        MinWidth="720"
        MinHeight="400"
        WindowStartupLocation="CenterOwner"
        Icon="/Assets/Icons/app.ico"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0"
                     Title="{DynamicResource History.Title}"
                     Icon="{ui:ImageIcon '/Assets/Icons/app-titlebar.png'}"
                     ShowMaximize="False"
                     ShowMinimize="False"
                     ShowClose="True" />

        <ui:Card Grid.Row="1" Margin="24,16,24,0" Padding="12">
            <ListView ItemsSource="{Binding Entries}"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      ScrollViewer.CanContentScroll="True">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="{DynamicResource History.Column.File}"
                                        DisplayMemberBinding="{Binding FileName}"
                                        Width="180" />
                        <GridViewColumn Header="{DynamicResource History.Column.Printer}"
                                        DisplayMemberBinding="{Binding PrinterName}"
                                        Width="160" />
                        <GridViewColumn Header="{DynamicResource History.Column.Started}"
                                        DisplayMemberBinding="{Binding StartedAtDisplay}"
                                        Width="140" />
                        <GridViewColumn Header="{DynamicResource History.Column.Result}"
                                        DisplayMemberBinding="{Binding ResultDisplay}"
                                        Width="100" />
                        <GridViewColumn Header="{DynamicResource History.Column.Copies}"
                                        DisplayMemberBinding="{Binding Copies}"
                                        Width="60" />
                        <GridViewColumn Header="{DynamicResource History.Column.Error}"
                                        DisplayMemberBinding="{Binding ErrorMessage}"
                                        Width="240" />
                    </GridView>
                </ListView.View>
            </ListView>
        </ui:Card>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="24">
            <ui:Button Content="{DynamicResource History.Refresh}"
                       Appearance="Secondary"
                       Command="{Binding RefreshCommand}"
                       Margin="0,0,8,0" />
            <ui:Button Content="{DynamicResource History.Clear}"
                       Appearance="Secondary"
                       Command="{Binding ClearHistoryCommand}"
                       Margin="0,0,8,0" />
            <ui:Button Content="{DynamicResource Button.Close}"
                       Command="{Binding CloseCommand}" />
        </StackPanel>
    </Grid>
</ui:FluentWindow>
