<ui:FluentWindow x:Class="PrintMaestro.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:dd="urn:gong-wpf-dragdrop"
        xmlns:models="clr-namespace:PrintMaestro.Core.Models;assembly=PrintMaestro.Core"
        Title="{DynamicResource App.Title}"
        Width="1280"
        Height="800"
        MinWidth="960"
        MinHeight="640"
        AllowDrop="True"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar x:Name="TitleBar"
                     Grid.Row="0"
                     Title="{DynamicResource App.Title}"
                     ShowMinimize="True"
                     ShowMaximize="True"
                     ShowClose="True">
            <ui:TitleBar.Icon>
                <ui:SymbolIcon Symbol="Print24" />
            </ui:TitleBar.Icon>
            <ui:TitleBar.TrailingContent>
                <StackPanel Orientation="Horizontal">
                    <ui:Button Appearance="Transparent"
                               ToolTip="{DynamicResource Menu.History}"
                               Icon="{ui:SymbolIcon Symbol=History24}"
                               Command="{Binding OpenHistoryCommand}" />
                    <ui:Button Appearance="Transparent"
                               ToolTip="{DynamicResource Menu.Settings}"
                               Icon="{ui:SymbolIcon Symbol=Settings24}"
                               Command="{Binding OpenSettingsCommand}" />
                </StackPanel>
            </ui:TitleBar.TrailingContent>
        </ui:TitleBar>

        <Grid Grid.Row="1" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                <ui:Button Content="{DynamicResource Button.AddFiles}"
                           Icon="{ui:SymbolIcon Symbol=DocumentAdd24}"
                           Command="{Binding AddDocumentsCommand}"
                           Margin="0,0,8,0" />
                <ui:Button Content="{DynamicResource Button.AddFolder}"
                           Appearance="Secondary"
                           Icon="{ui:SymbolIcon Symbol=FolderOpen24}"
                           Command="{Binding AddFolderCommand}"
                           Margin="0,0,8,0" />
                <ui:Button Content="{DynamicResource Button.StartPrint}"
                           Appearance="Primary"
                           Icon="{ui:SymbolIcon Symbol=Play24}"
                           Command="{Binding StartPrintCommand}"
                           Visibility="{Binding ShowStartPrint, Converter={StaticResource BoolToVis}}"
                           Margin="0,0,8,0" />
                <ui:Button Content="{DynamicResource Button.ResumePrint}"
                           Appearance="Primary"
                           Icon="{ui:SymbolIcon Symbol=Play24}"
                           Command="{Binding StartPrintCommand}"
                           Visibility="{Binding ShowResumePrint, Converter={StaticResource BoolToVis}}"
                           Margin="0,0,8,0" />
                <ui:Button Content="{DynamicResource Button.Pause}"
                           Appearance="Secondary"
                           Icon="{ui:SymbolIcon Symbol=Pause24}"
                           Command="{Binding PausePrintCommand}"
                           Visibility="{Binding ShowPausePrint, Converter={StaticResource BoolToVis}}"
                           Margin="0,0,8,0" />
                <ui:Button Content="{DynamicResource Button.CancelPrint}"
                           Appearance="Secondary"
                           Icon="{ui:SymbolIcon Symbol=Dismiss24}"
                           Command="{Binding CancelPrintCommand}"
                           Visibility="{Binding ShowCancelPrint, Converter={StaticResource BoolToVis}}" />
            </StackPanel>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="420" />
                    <ColumnDefinition Width="320" />
                </Grid.ColumnDefinitions>

                <ui:Card Grid.Column="0" Margin="0,0,16,0" Padding="16">
                    <DockPanel LastChildFill="True">
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="{DynamicResource Queue.Title}"
                                       FontSize="16"
                                       FontWeight="SemiBold" />
                            <ui:Button Content="{DynamicResource Button.ClearCompleted}"
                                       Appearance="Secondary"
                                       Margin="16,0,0,0"
                                       Command="{Binding ClearCompletedCommand}" />
                        </StackPanel>

                        <ListView x:Name="JobsListView"
                                  ItemsSource="{Binding Jobs}"
                                  dd:DragDrop.IsDragSource="True"
                                  dd:DragDrop.IsDropTarget="True"
                                  dd:DragDrop.DropHandler="{Binding}"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling"
                                  ScrollViewer.CanContentScroll="True">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="ContextMenu">
                                        <Setter.Value>
                                            <ContextMenu>
                                                <MenuItem Header="{DynamicResource Menu.PauseJob}"
                                                          Command="{Binding DataContext.PauseJobCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                <MenuItem Header="{DynamicResource Menu.ResumeJob}"
                                                          Command="{Binding DataContext.ResumeJobCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                <MenuItem Header="{DynamicResource Menu.RetryJob}"
                                                          Command="{Binding DataContext.RetryJobCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                <Separator />
                                                <MenuItem Header="{DynamicResource Menu.CancelJob}"
                                                          Command="{Binding DataContext.CancelJobCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                <MenuItem Header="{DynamicResource Button.Remove}"
                                                          Command="{Binding DataContext.RemoveJobCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                            </ContextMenu>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="48" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0"
                                                Width="40"
                                                Height="40"
                                                Margin="0,0,8,0"
                                                CornerRadius="4"
                                                Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}">
                                            <Image Source="{Binding Thumbnail}"
                                                   Stretch="Uniform"
                                                   Margin="2" />
                                        </Border>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding FileName}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding FilePath}"
                                                       Opacity="0.7"
                                                       FontSize="12"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding LocalizedStatus}" FontSize="12" Margin="0,4,0,0" />
                                        </StackPanel>
                                        <ui:Button Grid.Column="2"
                                                   Appearance="Secondary"
                                                   Content="{DynamicResource Button.Remove}"
                                                   Command="{Binding DataContext.RemoveJobCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                   CommandParameter="{Binding}" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </DockPanel>
                </ui:Card>

                <ui:Card Grid.Column="1" Padding="16">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Settings.Title}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,12" />

                        <TextBlock Text="{DynamicResource Profiles.Select}" Margin="0,0,0,4" />
                        <ComboBox ItemsSource="{Binding PrintProfiles}"
                                  SelectedItem="{Binding SelectedPrintProfile}"
                                  DisplayMemberPath="Name"
                                  Margin="0,0,0,8" />
                        <ui:Button Content="{DynamicResource Profiles.SaveCurrent}"
                                   Appearance="Secondary"
                                   Command="{Binding SavePrintProfileCommand}"
                                   Margin="0,0,0,16"
                                   HorizontalAlignment="Stretch" />

                        <TextBlock Text="{DynamicResource Settings.Printer}" Margin="0,0,0,4" />
                        <ComboBox ItemsSource="{Binding Printers}"
                                  SelectedItem="{Binding SelectedPrinter}"
                                  Margin="0,0,0,12" />

                        <TextBlock Text="{DynamicResource Settings.PaperFormat}" Margin="0,0,0,4" />
                        <ComboBox SelectedValue="{Binding PaperFormat}" Margin="0,0,0,12">
                            <models:PaperFormat>A4</models:PaperFormat>
                            <models:PaperFormat>A3</models:PaperFormat>
                        </ComboBox>

                        <TextBlock Text="{DynamicResource Settings.Orientation}" Margin="0,0,0,4" />
                        <ComboBox SelectedValue="{Binding Orientation}" Margin="0,0,0,12">
                            <models:PaperOrientation>Auto</models:PaperOrientation>
                            <models:PaperOrientation>Portrait</models:PaperOrientation>
                            <models:PaperOrientation>Landscape</models:PaperOrientation>
                        </ComboBox>

                        <TextBlock Text="{DynamicResource Settings.Copies}" Margin="0,0,0,4" />
                        <ui:NumberBox Value="{Binding Copies}"
                                      Minimum="1"
                                      Maximum="999"
                                      Margin="0,0,0,12" />

                        <CheckBox Content="{DynamicResource Settings.Duplex}"
                                  IsChecked="{Binding DuplexEnabled}"
                                  Margin="0,0,0,12" />

                        <CheckBox Content="{DynamicResource Settings.InsertBlankPageAfter}"
                                  IsChecked="{Binding InsertBlankPageAfter}" />
                    </StackPanel>
                </ui:Card>
            </Grid>

            <Border Grid.Row="2"
                    Margin="0,16,0,0"
                    Padding="12"
                    CornerRadius="8"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <TextBlock Text="{DynamicResource StatusBar.Total}" Margin="0,0,4,0" />
                        <TextBlock Text="{Binding TotalCount}" FontWeight="SemiBold" Margin="0,0,16,0" />
                        <TextBlock Text="{DynamicResource StatusBar.Completed}" Margin="0,0,4,0" />
                        <TextBlock Text="{Binding CompletedCount}" FontWeight="SemiBold" Margin="0,0,16,0" />
                        <TextBlock Text="{DynamicResource StatusBar.Errors}" Margin="0,0,4,0" />
                        <TextBlock Text="{Binding FailedCount}" FontWeight="SemiBold" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <ui:SnackbarPresenter x:Name="SnackbarPresenter"
                              Grid.Row="1"
                              Panel.ZIndex="1000"
                              VerticalAlignment="Bottom"
                              HorizontalAlignment="Right"
                              Margin="24" />
    </Grid>
</ui:FluentWindow>
