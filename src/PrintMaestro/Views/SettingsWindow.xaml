<ui:FluentWindow x:Class="PrintMaestro.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="{DynamicResource Settings.AppTitle}"
        Width="520"
        Height="480"
        MinWidth="460"
        MinHeight="420"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Acrylic">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0"
                     Title="{DynamicResource Settings.AppTitle}"
                     ShowMaximize="False"
                     ShowMinimize="False"
                     ShowClose="True" />

        <TabControl Grid.Row="1" Margin="24,16,24,0">
            <TabItem>
                <TabItem.Header>
                    <TextBlock Text="{DynamicResource Settings.Tab.General}" />
                </TabItem.Header>
                <StackPanel Margin="8">
                    <TextBlock Text="{DynamicResource Settings.Language}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8" />
                    <ComboBox ItemsSource="{Binding AvailableCultures}"
                              SelectedItem="{Binding SelectedCulture}" />
                </StackPanel>
            </TabItem>

            <TabItem>
                <TabItem.Header>
                    <TextBlock Text="{DynamicResource Settings.Tab.Profiles}" />
                </TabItem.Header>
                <DockPanel Margin="8">
                    <StackPanel DockPanel.Dock="Bottom"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,12,0,0">
                        <ui:Button Content="{DynamicResource Profiles.Delete}"
                                   Appearance="Secondary"
                                   Command="{Binding DeleteProfileCommand}" />
                    </StackPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="{DynamicResource Profiles.ManageHint}"
                               TextWrapping="Wrap"
                               Opacity="0.8"
                               Margin="0,0,0,12" />
                    <ListBox ItemsSource="{Binding PrintProfiles}"
                             SelectedItem="{Binding SelectedProfile}"
                             DisplayMemberPath="Name" />
                </DockPanel>
            </TabItem>

            <TabItem>
                <TabItem.Header>
                    <TextBlock Text="{DynamicResource Settings.Tab.About}" />
                </TabItem.Header>
                <StackPanel Margin="8">
                    <TextBlock Text="{DynamicResource About.Title}"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="{DynamicResource About.Version}" />
                        <TextBlock Text="{Binding AppVersion}"
                                   FontWeight="SemiBold"
                                   Margin="4,0,0,0" />
                    </StackPanel>
                    <TextBlock Text="{DynamicResource About.Description}"
                               TextWrapping="Wrap"
                               Opacity="0.85"
                               Margin="0,0,0,16" />
                    <ui:Button Content="{DynamicResource About.OpenLicenses}"
                               Appearance="Secondary"
                               HorizontalAlignment="Left"
                               Command="{Binding OpenThirdPartyLicensesCommand}" />
                </StackPanel>
            </TabItem>
        </TabControl>

        <ui:Button Grid.Row="2"
                   Content="{DynamicResource Button.Close}"
                   HorizontalAlignment="Right"
                   Margin="24"
                   Command="{Binding CloseCommand}" />
    </Grid>
</ui:FluentWindow>
