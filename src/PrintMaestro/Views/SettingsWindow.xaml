<ui:FluentWindow x:Class="PrintMaestro.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="{DynamicResource Settings.AppTitle}"
        Width="520"
        Height="480"
        MinWidth="460"
        MinHeight="420"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Icon="/Assets/Icons/app.ico"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Acrylic">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0"
                     Title="{DynamicResource Settings.AppTitle}"
                     Icon="{ui:ImageIcon '/Assets/Icons/app-titlebar.png'}"
                     ShowMaximize="False"
                     ShowMinimize="False"
                     ShowClose="True" />

        <TabControl Grid.Row="1" Margin="24,16,24,0">
            <TabItem>
                <TabItem.Header>
                    <TextBlock Text="{DynamicResource Settings.Tab.General}" />
                </TabItem.Header>
                <StackPanel Margin="8">
                    <TextBlock Text="{DynamicResource Settings.Language}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8" />
                    <ComboBox ItemsSource="{Binding AvailableCultures}"
                              SelectedItem="{Binding SelectedCulture}"
                              Margin="0,0,0,20" />

                    <TextBlock Text="{DynamicResource Settings.PdfRenderDpi}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,4" />
                    <ui:NumberBox Value="{Binding PdfRenderDpi}"
                                  Minimum="150"
                                  Maximum="400"
                                  SpinButtonPlacementMode="Compact"
                                  Margin="0,0,0,8" />
                    <TextBlock Text="{DynamicResource Settings.PdfRenderDpiHint}"
                               TextWrapping="Wrap"
                               Opacity="0.75"
                               FontSize="12" />
                </StackPanel>
            </TabItem>

            <TabItem>
                <TabItem.Header>
                    <TextBlock Text="{DynamicResource Settings.Tab.Profiles}" />
                </TabItem.Header>
                <DockPanel Margin="8">
                    <Grid DockPanel.Dock="Bottom" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:Button Grid.Column="0"
                                   Content="{DynamicResource Profiles.SaveCurrent}"
                                   Appearance="Primary"
                                   Command="{Binding SaveProfileCommand}"
                                   Margin="0,0,8,0"
                                   HorizontalAlignment="Stretch" />
                        <ui:Button Grid.Column="1"
                                   Content="{DynamicResource Profiles.Delete}"
                                   Appearance="Secondary"
                                   Command="{Binding DeleteProfileCommand}" />
                    </Grid>
                    <TextBlock DockPanel.Dock="Top"
                               Text="{DynamicResource Profiles.ManageHint}"
                               TextWrapping="Wrap"
                               Opacity="0.8"
                               Margin="0,0,0,12" />
                    <ListBox ItemsSource="{Binding PrintProfiles}"
                             SelectedItem="{Binding SelectedProfile}"
                             DisplayMemberPath="Name" />
                </DockPanel>
            </TabItem>

            <TabItem>
                <TabItem.Header>
                    <TextBlock Text="{DynamicResource Settings.Tab.About}" />
                </TabItem.Header>
                <StackPanel Margin="8">
                    <Border Width="96"
                            Height="96"
                            CornerRadius="20"
                            Background="Transparent"
                            ClipToBounds="True"
                            Margin="0,0,0,12">
                        <Image Source="{StaticResource AppLogoImage}"
                               Stretch="UniformToFill"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                    </Border>
                    <TextBlock Text="{DynamicResource About.Title}"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="{DynamicResource About.Version}" />
                        <TextBlock Text="{Binding AppVersion}"
                                   FontWeight="SemiBold"
                                   Margin="4,0,0,0" />
                    </StackPanel>
                    <TextBlock Text="{DynamicResource About.Description}"
                               TextWrapping="Wrap"
                               Opacity="0.85"
                               Margin="0,0,0,16" />
                    <ui:Button Content="{DynamicResource About.OpenLicenses}"
                               Appearance="Secondary"
                               HorizontalAlignment="Left"
                               Command="{Binding OpenThirdPartyLicensesCommand}" />
                </StackPanel>
            </TabItem>
        </TabControl>

        <ui:Button Grid.Row="2"
                   Content="{DynamicResource Button.Close}"
                   HorizontalAlignment="Right"
                   Margin="24"
                   Command="{Binding CloseCommand}" />
    </Grid>
</ui:FluentWindow>
